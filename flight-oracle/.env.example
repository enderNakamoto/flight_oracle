# -----------------------------------------------
# RPC endpoint for the chain the aggregator is on
# e.g. Hedera testnet JSON-RPC relay or any EVM-compatible RPC
# -----------------------------------------------
RPC_URL=https://testnet.hashio.io/api

# -----------------------------------------------
# Deployed FlightDataAggregator contract address
# -----------------------------------------------
AGGREGATOR_ADDRESS=0xYourAggregatorAddressHere

# -----------------------------------------------
# Oracle wallet — this address must be set as
# authorizedOracle in the aggregator contract
# -----------------------------------------------
ORACLE_PRIVATE_KEY=0xYourPrivateKeyHere

# -----------------------------------------------
# FlightAware AeroAPI key
# https://www.flightaware.com/aeroapi/portal
# For Phase 2 (local chain + integration.test.ts), use "mock" — HTTP is mocked.
# -----------------------------------------------
FLIGHTAWARE_API_KEY=your_flightaware_api_key_here

# -----------------------------------------------
# Optional: delay threshold in minutes above which
# a flight is considered "Delayed" (default: 15)
# -----------------------------------------------
DELAY_THRESHOLD_MINUTES=15
