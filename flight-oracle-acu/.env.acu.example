# ---------------------------------------------------
# .env.acu  —  local simulation environment
#
# Copy this file to .env.acu and fill in real values.
# NEVER commit .env.acu to git.
# ---------------------------------------------------

# Flag that activates the polyfill_acu.ts shim (local mode only)
LOCAL_MODE=true

# RPC endpoint (Anvil local chain for testing, or testnet)
RPC_URL=http://localhost:8545

# Deployed FlightDataAggregator contract address
AGGREGATOR_ADDRESS=0xYourAggregatorAddressHere

# Oracle wallet private key — must match the address set via setOracle()
# Use an Anvil test key locally e.g. 0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a
ORACLE_PRIVATE_KEY=0xYourPrivateKeyHere

# FlightAware AeroAPI key
FLIGHTAWARE_API_KEY=your_flightaware_api_key_here

# Delay threshold in minutes (flights delayed more than this are marked Delayed)
DELAY_THRESHOLD_MINUTES=15

# ---------------------------------------------------
# NOTE: On a real Acurast processor, ORACLE_PRIVATE_KEY is never needed.
# The TEE processor holds its own key and signs transactions natively.
# Only RPC_URL, AGGREGATOR_ADDRESS, FLIGHTAWARE_API_KEY and
# DELAY_THRESHOLD_MINUTES are declared in acurast.json and encrypted on-chain.
# ---------------------------------------------------
